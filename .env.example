# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack Signing Secret (từ Basic Information của Slack App)
# Cần thiết để xác thực payload khi user bấm Yes/No
# Cấu hình Interactivity: Request URL = https://your-domain/api/slack/interactivity
SLACK_SIGNING_SECRET=

# Channel mặc định (ví dụ: #general hoặc C01234567)
SLACK_CHANNEL=#hello-world

# Vercel Neon (Postgres) - lấy từ Vercel Dashboard > Storage > Neon
# Hoặc tạo DB tại https://neon.tech và copy connection string

# Parameters for Vercel Postgres Templates
POSTGRES_URL=postgresql://neondb_owner:xxxxxxxxxxxxxxxx@ep-fragrant-pine-a1ehby7r-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:xxxxxxxxxxxxxxxx@ep-fragrant-pine-a1ehby7r.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
POSTGRES_USER=neondb_owner
POSTGRES_HOST=ep-fragrant-pine-a1ehby7r-pooler.ap-southeast-1.aws.neon.tech
POSTGRES_PASSWORD=xxxxxxxxxxxxxxxx
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=postgresql://neondb_owner:xxxxxxxxxxxxxxxx@ep-fragrant-pine-a1ehby7r-pooler.ap-southeast-1.aws.neon.tech/neondb
POSTGRES_PRISMA_URL=postgresql://neondb_owner:xxxxxxxxxxxxxxxx@ep-fragrant-pine-a1ehby7r-pooler.ap-southeast-1.aws.neon.tech/neondb?connect_timeout=15&sslmode=require