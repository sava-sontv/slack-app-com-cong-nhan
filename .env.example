# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack Signing Secret (từ Basic Information của Slack App)
# Cần thiết để xác thực payload khi user bấm Yes/No
# Cấu hình Interactivity: Request URL = https://your-domain/api/slack/interactivity
SLACK_SIGNING_SECRET=

# Channel mặc định (ví dụ: #general hoặc C01234567)
SLACK_CHANNEL=#hello-world
